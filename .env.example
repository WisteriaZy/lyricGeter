# lyricGeter 环境配置
# 用法：复制本文件为 .env 并填入实际值（.env 已在 .gitignore 中，不会提交）
# 复制命令：Copy-Item .env.example .env   (PowerShell)   cp .env.example .env   (bash)
# 程序仅读取本目录下的 .env 文件，不读取系统环境变量

# —— LLM 翻译对齐校验（可选功能）——
# 用于「选择翻译来源合并」后的可选校验步骤。
# 支持任意 OpenAI 兼容的 Chat Completions 端点。

# OpenAI 兼容 API Key（留空则 LLM 校验功能不可用）
OPENAI_API_KEY=

# API 基础地址，默认 https://api.openai.com/v1
# 可换成任意 OpenAI 兼容端点，例如 Azure OpenAI Proxy、OpenRouter 等
# OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的模型名称，默认 gpt-4o-mini
# LYRICGETER_LLM_MODEL=gpt-4o-mini
